data/cve_database.db
data/cve_database.json
data/cve_cache.json

# Original research — never distributed
data/llm_attack_kb/original_research.md

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
.venv/
.env/

# Environment / secrets / future API keys
.env
.env.*
*.key
config.local.json
config.yaml

